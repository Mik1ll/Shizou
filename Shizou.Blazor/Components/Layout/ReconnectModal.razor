<script type="module" src="@Assets["Components/Layout/ReconnectModal.razor.js"]"></script>

<dialog id="components-reconnect-modal" data-nosnippet>
    <div class="d-flex flex-column align-items-center gap-3">
        <div class="components-rejoining-animation" aria-hidden="true">
            <div></div>
            <div></div>
        </div>
        <p class="components-reconnect-first-attempt-visible text-center mb-0">
            Rejoining the server...
        </p>
        <p class="components-reconnect-repeated-attempt-visible text-center mb-0">
            Rejoin failed... trying again in <span id="components-seconds-to-next-attempt"></span> seconds.
        </p>
        <p class="components-reconnect-failed-visible text-center mb-0">
            Failed to rejoin.<br/>Please retry or reload the page.
        </p>
        <button id="components-reconnect-button" class="btn btn-primary components-reconnect-failed-visible">
            Retry
        </button>
        <p class="components-pause-visible text-center mb-0">
            The session has been paused by the server.
        </p>
        <p class="components-resume-failed-visible text-center mb-0">
            Failed to resume the session.<br/>Please retry or reload the page.
        </p>
        <button id="components-resume-button" class="btn btn-primary components-pause-visible components-resume-failed-visible">
            Resume
        </button>
    </div>
</dialog>
