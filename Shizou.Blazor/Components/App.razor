@using Microsoft.AspNetCore.Identity
<!DOCTYPE html>
<html lang="en">
<!--suppress HtmlRequiredTitleElement -->
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <base href="/"/>

    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.css"]">
    <link rel="stylesheet" href="@Assets["lib/bootstrap-icons/font/bootstrap-icons.css"]"/>
    <link rel="stylesheet" href="@Assets["lib/video.js/dist/video-js.css"]"/>
    <link rel="stylesheet" href="@Assets["css/site.css"]"/>
    @* ReSharper disable Html.PathError *@
    <link rel="stylesheet" href="@Assets["Shizou.Blazor.styles.css"]"/>
    @* ReSharper restore Html.PathError *@
    <ImportMap/>

    @* Favicon start *@
    <link rel="icon" type="image/png" href="@Assets["favicon-96x96.png"]" sizes="96x96"/>
    <link rel="icon" type="image/svg+xml" href="@Assets["favicon.svg"]"/>
    <link rel="shortcut icon" href="@Assets["favicon.ico"]"/>
    <link rel="apple-touch-icon" sizes="180x180" href="@Assets["apple-touch-icon.png"]"/>
    @* Favicon end *@

    <link rel="manifest" href="@Assets["manifest.json"]"/>
    <meta name="theme-color" content="white">

    <HeadOutlet @rendermode="@RenderModeForPage"/>
</head>
<body class="invisible">
<Routes @rendermode="@RenderModeForPage" IdentityCookie="@(HttpContext.Request.Cookies[IdentityConstants.ApplicationScheme])"/>

@* ReSharper disable Html.PathError *@
<script src="@Assets["_framework/blazor.web.js"]"></script>
@* ReSharper restore Html.PathError *@

</body>
</html>

@code {

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = null!;

    private IComponentRenderMode? RenderModeForPage => HttpContext.Request.Path.StartsWithSegments("/Account")
        ? null
        : new InteractiveServerRenderMode(false);

}
